// Boardly data model
// Swap provider to "postgresql" + set DATABASE_URL to a postgres connection string
// for production use. SQLite is used here for zero-setup local/demo runs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  createdAt DateTime  @default(now())
  projects  Project[]
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String?
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  tasks       Task[]
  createdAt   DateTime @default(now())

  @@index([ownerId])
}

// SQLite has no native enum type, so status/priority are plain strings.
// Valid values are enforced at the API layer via Zod (see src/routes) —
// this is a deliberate tradeoff for the SQLite demo setup. Switching to
// Postgres later would let you promote these back to real Prisma enums.
model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  status      String    @default("TODO") // TODO | IN_PROGRESS | DONE
  priority    String    @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  dueDate     DateTime?
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
}
